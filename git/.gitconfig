[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[user]
	name = Jack Harter
	email = jack.harter@me.com
[pull]
	rebase = false
[core]
	pager = delta
	excludesfile = ~/.gitignore_global
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
	dark = true
	syntax-theme = Dracula
	side-by-side = false
[merge]
	conflictstyle = diff3
[credential]
    # Platform-specific override via ~/.gitconfig.local
    helper =
[include]
    path = ~/.gitconfig.local
[url "git@github.com:"]
	insteadOf = https://github.com/
[push]
	default = current
[alias]
	fixup = commit --fixup
	recent = branch --sort=-committerdate --format='%(refname:short)' -10
	aliases = config --get-regexp alias
